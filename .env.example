# -----------------------------------------------------------------------
# Supabase / Prisma database connection
# Use the "Transaction" pooler URL from Supabase for DATABASE_URL.
# DIRECT_URL is optional — only needed locally if you run `prisma migrate deploy` directly.
# -----------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------
# Odds API  (https://the-odds-api.com)
# -----------------------------------------------------------------------
ODDS_API_KEY=your_odds_api_key_here
ODDS_API_REGION=au
ODDS_API_MARKETS=h2h

# -----------------------------------------------------------------------
# Elo model configuration
# -----------------------------------------------------------------------
STARTING_ELO=1500
K_FACTOR=30
HOME_ADVANTAGE_ELO=50

# -----------------------------------------------------------------------
# Edge / confidence thresholds
# -----------------------------------------------------------------------
VALUE_EDGE_THRESHOLD=0.04
CONFIDENCE_MEDIUM_THRESHOLD=0.03
CONFIDENCE_HIGH_THRESHOLD=0.06

# -----------------------------------------------------------------------
# App
# -----------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=NRL Model
APP_TIMEZONE=Australia/Sydney
