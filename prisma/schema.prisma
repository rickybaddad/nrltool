generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum ImportRunStatus {
  SUCCESS
  PARTIAL
  FAILED
}

enum ImportRunType {
  BOOTSTRAP
  SYNC_SEASON
  SEED_TEAMS
  IMPORT_HISTORY
  IMPORT_FIXTURES
  IMPORT_ODDS
  REFRESH_RESULTS
  CALCULATE_RATINGS
  GENERATE_PREDICTIONS
  EVALUATE_PREDICTIONS
}

enum PredictionType {
  PRE_MATCH
}

enum PredictionScope {
  ROUND_VIEW
  SCHEDULED_RUN
  SEASON_SYNC
}

enum PredictionResultType {
  WIN
  LOSS
  DRAW
  NO_RESULT
  NO_PREDICTION
}

model Team {
  id              String               @id @default(cuid())
  slug            String               @unique
  fullName        String               @unique
  shortName       String               @unique
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  aliases         TeamAlias[]
  homeMatches     Match[]              @relation("HomeTeam")
  awayMatches     Match[]              @relation("AwayTeam")
  homeOdds        OddsSnapshot[]       @relation("HomeOddsTeam")
  awayOdds        OddsSnapshot[]       @relation("AwayOddsTeam")
  homePredictions Prediction[]         @relation("HomePredictionTeam")
  awayPredictions Prediction[]         @relation("AwayPredictionTeam")
  ratingSnapshots TeamRatingSnapshot[]

  @@index([slug])
}

model TeamAlias {
  id         String   @id @default(cuid())
  alias      String   @unique
  normalized String
  source     String
  teamId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([normalized])
  @@index([teamId])
}

model Match {
  id             String               @id @default(cuid())
  externalId     String?              @unique
  season         Int
  round          Int?
  kickoffAt      DateTime
  venue          String?
  status         MatchStatus          @default(SCHEDULED)
  source         String
  sourceUrl      String?
  homeTeamId     String
  awayTeamId     String
  homeScore      Int?
  awayScore      Int?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  homeTeam       Team                 @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam       Team                 @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  oddsSnapshots  OddsSnapshot[]
  predictions    Prediction[]
  ratingSnapshots TeamRatingSnapshot[]

  @@unique([season, round, homeTeamId, awayTeamId, kickoffAt])
  @@index([kickoffAt])
  @@index([status])
  @@index([season, round])
}

model TeamRatingSnapshot {
  id           String   @id @default(cuid())
  teamId       String
  matchId      String?
  season       Int
  ratingBefore Float
  ratingAfter  Float
  createdAt    DateTime @default(now())
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  match        Match?   @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([teamId, createdAt])
  @@index([season])
}

model OddsSnapshot {
  id                    String   @id @default(cuid())
  matchId               String
  bookmakerKey          String
  bookmakerTitle        String
  marketKey             String
  homeTeamId            String
  awayTeamId            String
  homePrice             Float
  awayPrice             Float
  homeImpliedProbability Float
  awayImpliedProbability Float
  homeNormalizedProb    Float
  awayNormalizedProb    Float
  overround             Float
  fetchedAt             DateTime @default(now())
  createdAt             DateTime @default(now())

  match                 Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homeTeam              Team     @relation("HomeOddsTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam              Team     @relation("AwayOddsTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)

  @@index([matchId, fetchedAt])
  @@index([bookmakerKey, fetchedAt])
}

model Prediction {
  id                    String               @id @default(cuid())
  matchId               String
  homeTeamId            String
  awayTeamId            String
  modelHomeProbability  Float
  modelAwayProbability  Float
  predictedWinnerTeamId String?
  actualWinnerTeamId    String?
  wasCorrect            Boolean?
  resultType            PredictionResultType?
  selectedBookmaker     String?
  marketHomeProbability Float?
  marketAwayProbability Float?
  homeEdge              Float?
  awayEdge              Float?
  confidence            String
  predictionType        PredictionType       @default(PRE_MATCH)
  predictionScope       PredictionScope      @default(SCHEDULED_RUN)
  modelVersion          String               @default("elo-v1")
  lockedAt              DateTime?
  generatedAt           DateTime             @default(now())
  evaluatedAt           DateTime?
  usedForEvaluation     Boolean              @default(false)
  createdAt             DateTime             @default(now())

  match                 Match                @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homeTeam              Team                 @relation("HomePredictionTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam              Team                 @relation("AwayPredictionTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)

  @@unique([matchId, generatedAt])
  @@index([matchId, generatedAt])
  @@index([predictionType, predictionScope, generatedAt])
  @@index([usedForEvaluation])
}

model ImportRun {
  id             String          @id @default(cuid())
  type           ImportRunType
  status         ImportRunStatus
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  message        String?
  recordsRead    Int             @default(0)
  recordsWritten Int             @default(0)
  metadata       Json?

  @@index([type, startedAt])
  @@index([status, startedAt])
}
